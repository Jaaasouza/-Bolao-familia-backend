# Postgres connection (Railway: ${{Postgres.DATABASE_URL}})
DATABASE_URL=postgres://postgres:test@localhost:5432/postgres

# Auth
JWT_SECRET=change-me-32-char-random-openssl-rand-hex-32
JWT_TTL=7d
# Password exchanged at POST /api/auth/login for an admin JWT
ADMIN_PASSWORD=2026

# CORS — comma-separated list of allowed origins (empty = allow all)
ALLOWED_ORIGINS=

# football-data.org (free tier: 10 req/min)
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION=WC
# Polling interval for the scheduler (ms)
SYNC_INTERVAL_MS=60000

# Server
PORT=3000
NODE_ENV=development
